# name: test/sql/raw_advanced.test
# description: RawDuck streaming file ingestion and adaptive ORDER BY optimization
# group: [sql]

require rawduck

require json

#===----------------------------------------------------------------------===#
# raw_ingest_file: streaming NDJSON ingestion
#===----------------------------------------------------------------------===#

statement ok
COPY (SELECT 1 AS id, 'click' AS action UNION ALL SELECT 2, 'view') TO '__TEST_DIR__/events.ndjson' (FORMAT json);

query IIIIIII
SELECT * FROM raw_ingest_file('t_file', '__TEST_DIR__/events.ndjson');
----
t_file	true	2	0	2	0	1

query II
SELECT id, action FROM t_file ORDER BY id;
----
1	click
2	view

# small batches: schema evolution across batch boundaries
statement ok
COPY (SELECT range AS n FROM range(10)) TO '__TEST_DIR__/r.ndjson' (FORMAT json);

query II
SELECT rows, batches FROM raw_ingest_file('t_batches', '__TEST_DIR__/r.ndjson', batch_size := 3);
----
10	4

query II
SELECT count(*), sum(n) FROM t_batches;
----
10	45

# gzip-compressed input is auto-detected
statement ok
COPY (SELECT 7 AS z) TO '__TEST_DIR__/z.ndjson.gz' (FORMAT json, COMPRESSION gzip);

query I
SELECT rows FROM raw_ingest_file('t_gz', '__TEST_DIR__/z.ndjson.gz');
----
1

query I
SELECT z FROM t_gz;
----
7

statement error
SELECT * FROM raw_ingest_file('t_x', '__TEST_DIR__/does_not_exist.ndjson');
----
<REGEX>:.*does_not_exist.*

statement error
SELECT * FROM raw_ingest_file('t_x', '__TEST_DIR__/events.ndjson', batch_size := 0);
----
<REGEX>:.*batch_size must be positive.*

#===----------------------------------------------------------------------===#
# raw_stats / raw_optimize: adaptive ORDER BY from observed predicates
#===----------------------------------------------------------------------===#

statement ok
SELECT * FROM raw_ingest('t_opt', '[{"k":"a","v":1},{"k":"b","v":2},{"k":"a","v":3}]');

# observe some pushed-down predicates: k is filtered more often than v
statement ok
SELECT count(*) FROM t_opt WHERE k = 'a';

statement ok
SELECT count(*) FROM t_opt WHERE k = 'b';

statement ok
SELECT count(*) FROM t_opt WHERE v > 1;

query IIII
SELECT "table", "column", filter_count >= 1, group_count FROM raw_stats() WHERE "table" = 'memory.main.t_opt' ORDER BY "column";
----
memory.main.t_opt	k	true	0
memory.main.t_opt	v	true	0

# physically reorder by the hottest predicate columns
query IIII
SELECT "table", order_by, rows, mode FROM raw_optimize('t_opt');
----
t_opt	"k", "v"	3	full

# data survives and is now physically ordered by k, v
query II
SELECT k, v FROM t_opt;
----
a	1
a	3
b	2

query I
SELECT count(*) FROM t_opt WHERE k = 'a';
----
2

# optimizing a table without observed predicates is a no-op
statement ok
SELECT * FROM raw_ingest('t_nostats', '[{"x":1}]');

query IIII
SELECT "table", order_by IS NULL, rows, mode FROM raw_optimize('t_nostats');
----
t_nostats	true	0	noop

query I
SELECT x FROM t_nostats;
----
1

#===----------------------------------------------------------------------===#
# ingest-time transforms: explode envelope arrays into rows
#===----------------------------------------------------------------------===#

# generic explode: one row per array element, envelope fields merged in
query III
SELECT id, message, "logGroup" FROM raw_records('{"logGroup":"/aws/lambda/api","logEvents":[{"id":1,"message":"started"},{"id":2,"message":"done"}]}', explode := 'logEvents') ORDER BY id;
----
1	started	/aws/lambda/api
2	done	/aws/lambda/api

# named transform from the built-in catalog
query II
SELECT id, "owner" FROM raw_records('{"owner":"123","logEvents":[{"id":7}]}', transform := 'cloudwatch-logs');
----
7	123

# element fields win over envelope fields on collision
query I
SELECT v FROM raw_records('{"v":"envelope","items":[{"v":"element"}]}', explode := 'items');
----
element

# rows without the array pass through unchanged
query II
SELECT a, count(*) FROM raw_records(e'{"a":1}\n{"a":2,"items":[{"a":3}]}', explode := 'items') GROUP BY a ORDER BY a;
----
1	1
3	1

statement ok
SELECT * FROM raw_ingest('t_cw', '{"owner":"o1","logEvents":[{"id":1},{"id":2}]}', transform := 'cloudwatch-logs');

query II
SELECT count(*), max(id) FROM t_cw;
----
2	2

statement error
SELECT * FROM raw_records('{}', transform := 'nope');
----
<REGEX>:.*unknown transform.*

statement error
SELECT * FROM raw_records('{}', transform := 'cloudwatch-logs', explode := 'x');
----
<REGEX>:.*either transform or explode.*

#===----------------------------------------------------------------------===#
# ignore_errors: skip and count unparseable NDJSON lines
#===----------------------------------------------------------------------===#

query II
SELECT rows, errors FROM raw_ingest('t_dirty', e'{"a":1}\n{not json}\n{"a":2}', ignore_errors := true);
----
2	1

query I
SELECT sum(a) FROM t_dirty;
----
3

statement error
SELECT * FROM raw_ingest('t_dirty2', e'{"a":1}\n{not json}');
----
<REGEX>:.*parse error on line 2.*

# multi-level explode: OTLP traces
query II
SELECT name, "resource.service" FROM raw_records('{"resourceSpans":[{"resource":{"service":"api"},"scopeSpans":[{"spans":[{"name":"s1"},{"name":"s2"}]}]}]}', transform := 'otlp-traces') ORDER BY name;
----
s1	api
s2	api

# user-defined transforms compose with any source
query I
SELECT raw_transform_define('my-batch', 'data.items');
----
my-batch

query II
SELECT id, src FROM raw_records('{"src":"q","data":{"items":[{"id":1}]}}', transform := 'my-batch');
----
1	q

query II
SELECT name, builtin FROM raw_transforms() WHERE name IN ('otlp-traces', 'my-batch') ORDER BY name;
----
my-batch	false
otlp-traces	true

statement error
SELECT raw_transform_define('cloudwatch-logs', 'x');
----
<REGEX>:.*built-in transform.*

#===----------------------------------------------------------------------===#
# multi-threaded appends (pool engages above 4096 rows per batch)
#===----------------------------------------------------------------------===#

statement ok
COPY (SELECT range AS n, 'v' || (range % 7) AS v FROM range(20000)) TO '__TEST_DIR__/big.ndjson' (FORMAT json);

query II
SELECT rows, errors FROM raw_ingest_file('t_mt', '__TEST_DIR__/big.ndjson', batch_size := 6000);
----
20000	0

query III
SELECT count(*), count(DISTINCT n), sum(n) FROM t_mt;
----
20000	20000	199990000

# schema evolution drains the pool correctly mid-stream
statement ok
COPY (SELECT range AS n, range * 1.5 AS extra FROM range(5000)) TO '__TEST_DIR__/big2.ndjson' (FORMAT json);

query I
SELECT rows FROM raw_ingest_file('t_mt', '__TEST_DIR__/big2.ndjson');
----
5000

query III
SELECT count(*), count(extra), max(extra) FROM t_mt;
----
25000	5000	7498.5

#===----------------------------------------------------------------------===#
# auto-projections: advisor observes aggregations, raw_project materializes
#===----------------------------------------------------------------------===#

statement ok
SELECT * FROM raw_ingest('t_proj', '[{"k":"a","g":1},{"k":"b","g":1},{"k":"a","g":2}]');

statement ok
SELECT k, count(*) FROM t_proj GROUP BY k;

statement ok
SELECT k, count(*) FROM t_proj GROUP BY k;

statement ok
SELECT g, count(*) FROM t_proj GROUP BY g;

query III
SELECT group_columns, observed >= 1, projection IS NULL FROM raw_projections() WHERE "table" = 'memory.main.t_proj' ORDER BY group_columns;
----
g	true	true
k	true	true

query III
SELECT projection, group_columns, rows FROM raw_project('t_proj');
----
t_proj__proj	k	2

query II
SELECT k, count FROM t_proj__proj ORDER BY k;
----
a	2
b	1

# advisor now shows the materialized projection
query I
SELECT projection FROM raw_projections() WHERE "table" = 'memory.main.t_proj' AND group_columns = 'k';
----
t_proj__proj

# no observations: no-op
statement ok
SELECT * FROM raw_ingest('t_noproj', '[{"x":1}]');

query II
SELECT projection IS NULL, rows FROM raw_project('t_noproj');
----
true	0

# incremental optimize: appended rows form a new sorted run; unchanged is a no-op
query I
SELECT mode FROM raw_optimize('t_opt');
----
noop

statement ok
SELECT * FROM raw_ingest('t_opt', '[{"k":"c","v":9},{"k":"a","v":0}]');

query II
SELECT rows, mode FROM raw_optimize('t_opt');
----
2	incremental

query II
SELECT count(*), min(v) FROM t_opt WHERE k = 'a';
----
3	0

#===----------------------------------------------------------------------===#
# automatic aggregate rewriting onto fresh projections
#===----------------------------------------------------------------------===#

statement ok
SELECT * FROM raw_project('t_proj');

statement ok
SET rawduck_use_projections = true;

# correct results through the projection
query II
SELECT k, count(*) FROM t_proj GROUP BY k ORDER BY k;
----
a	2
b	1

# prove the projection is being scanned: temper with it and observe
statement ok
UPDATE t_proj__proj SET count = 100 WHERE k = 'a';

query II
SELECT k, count(*) FROM t_proj GROUP BY k ORDER BY k;
----
a	100
b	1

# any base-table change invalidates the projection: falls back to the base
statement ok
SELECT * FROM raw_ingest('t_proj', '[{"k":"b","g":3}]');

query II
SELECT k, count(*) FROM t_proj GROUP BY k ORDER BY k;
----
a	2
b	2

# filtered or non-count aggregations are never rewritten
query II
SELECT k, count(*) FROM t_proj WHERE g > 0 GROUP BY k ORDER BY k;
----
a	2
b	2

statement ok
SET rawduck_use_projections = false;

query II
SELECT k, count(*) FROM t_proj GROUP BY k ORDER BY k;
----
a	2
b	2

#===----------------------------------------------------------------------===#
# realtime-style small inserts: many tiny payloads with rotating shapes
#===----------------------------------------------------------------------===#

loop i 0 50

statement ok
SELECT * FROM raw_ingest('t_rt', '[{"u":"a${i}","v":${i}}]');

statement ok
SELECT * FROM raw_ingest('t_rt', '[{"u":"b${i}","page":"/p","ms":${i}.5},{"u":"c${i}","v":${i}}]');

statement ok
SELECT * FROM raw_ingest('t_rt', '{"svc":"api","code":${i}}');

endloop

query III
SELECT count(*), count(DISTINCT u), max(code) FROM t_rt;
----
200	150	49

#===----------------------------------------------------------------------===#
# asynchronous inserts (ClickHouse async_insert-style, opt-in)
#===----------------------------------------------------------------------===#

statement ok
SET rawduck_async_insert = true;

# enqueued, not yet visible
query II
SELECT rows, created FROM raw_ingest('t_async', '[{"a":1},{"a":2}]');
----
0	false

statement ok
SELECT * FROM raw_ingest('t_async', '[{"a":3,"b":"x"}]');

statement error
SELECT count(*) FROM t_async;
----
<REGEX>:.*does not exist.*

# raw_flush drains the buffers synchronously
query II
SELECT targets, rows FROM raw_flush();
----
1	3

query II
SELECT count(*), count(b) FROM t_async;
----
3	1

statement ok
SET rawduck_async_insert = false;

# OTLP semantic normalization: KeyValue attributes spread into flat columns,
# AnyValue unwraps, *UnixNano digit-strings become integers
query IIIIII
SELECT body, pod, status, "resource.service.name", "timeUnixNano", typeof("timeUnixNano")
FROM raw_records('{"resourceLogs":[{"resource":{"attributes":[{"key":"service.name","value":{"stringValue":"api"}}]},"scopeLogs":[{"scope":{"name":"http"},"logRecords":[{"timeUnixNano":"1718000000000000000","body":{"stringValue":"request ok"},"attributes":[{"key":"pod","value":{"stringValue":"pod-a"}},{"key":"status","value":{"intValue":"200"}}]}]}]}]}', transform := 'otlp-logs');
----
request ok	pod-a	200	api	1718000000000000000	BIGINT

# OTLP id normalization: protobuf's JSON conversion (gRPC / OTLP-HTTP protobuf
# bodies) emits trace/span ids as base64; OTLP/JSON mandates hex
query III
SELECT "traceId", "spanId", "parentSpanId"
FROM raw_records('{"resourceSpans":[{"scopeSpans":[{"spans":[{"traceId":"AQIDBAUGBwgJCgsMDQ4PEA==","spanId":"AQIDBAUGBwg=","parentSpanId":"AQIDBAUGBwg=","name":"op"}]}]}]}', transform := 'otlp-traces');
----
0102030405060708090a0b0c0d0e0f10	0102030405060708	0102030405060708

# already-hex ids (OTLP/JSON senders) pass through untouched
query II
SELECT "traceId", "spanId"
FROM raw_records('{"resourceLogs":[{"scopeLogs":[{"logRecords":[{"traceId":"5B8EFFF798038103D269B633813FC60C","spanId":"EEE19B7EC3C1B174","body":{"stringValue":"x"}}]}]}]}', transform := 'otlp-logs');
----
5B8EFFF798038103D269B633813FC60C	EEE19B7EC3C1B174
