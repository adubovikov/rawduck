# name: test/sql/ducklake.test
# description: RawDuck schema-less ingestion into a DuckLake catalog
# group: [sql]

require rawduck

require json

require parquet

statement ok
INSTALL ducklake;

statement ok
LOAD ducklake;

statement ok
ATTACH 'ducklake:__TEST_DIR__/rawlake.ducklake' AS lake (DATA_PATH '__TEST_DIR__/rawlake_data');

query IIIIII
SELECT * FROM raw_ingest('lake.main.events', '[{"id":1,"action":"click","ts":"2024-01-15T10:30:00"}]');
----
lake.main.events	true	3	0	1	0

query III
SELECT id, action, ts FROM lake.main.events;
----
1	click	2024-01-15 10:30:00

# schema evolution against the DuckLake catalog
query IIIIII
SELECT * FROM raw_ingest('lake.main.events', '[{"id":2,"action":"view","user":{"name":"alice"}}]');
----
lake.main.events	false	1	0	1	0

query II
SELECT id, "user.name" FROM lake.main.events ORDER BY id;
----
1	NULL
2	alice

# type widening through DuckLake's supported promotions (INTEGER -> BIGINT);
# promotions outside DuckLake's set (e.g. BIGINT -> DOUBLE) are version-
# dependent and surface DuckLake's own error instead
statement ok
CREATE TABLE lake.main.manual (id INTEGER, action VARCHAR);

query IIIIII
SELECT * FROM raw_ingest('lake.main.manual', '[{"id":9999999999,"action":"buy"}]');
----
lake.main.manual	false	0	1	1	0

query II
SELECT typeof(id), max(id) FROM lake.main.manual GROUP BY ALL;
----
BIGINT	9999999999
