# name: test/sql/raw_attach.test
# description: ATTACH 'rawduck:...' stores: native DuckDB queries over RawMergeTree tables
# group: [sql]

require rawduck

require json

statement ok
ATTACH 'rawduck:__TEST_DIR__/store.db' AS raw;

# the attached store identifies as a rawduck database
query I
SELECT type FROM duckdb_databases() WHERE database_name = 'raw';
----
rawduck

# schema-less ingestion straight into the store
query IIIIII
SELECT * FROM raw_ingest('raw.events', '[{"id":1,"name":"a","ts":"2024-01-15T10:30:00"}]');
----
raw.events	true	3	0	1	0

# regular DuckDB statements work transparently on RawMergeTree tables
query III
SELECT id, name, ts FROM raw.events;
----
1	a	2024-01-15 10:30:00

statement ok
INSERT INTO raw.events VALUES (2, 'b', '2024-01-15T11:00:00');

statement ok
UPDATE raw.events SET name = 'c' WHERE id = 2;

query II
SELECT id, name FROM raw.events ORDER BY id;
----
1	a
2	c

statement ok
CREATE TABLE raw.manual AS SELECT 42 AS answer;

query I
SELECT answer FROM raw.manual;
----
42

# schema evolution against the attached store
query IIIIII
SELECT * FROM raw_ingest('raw.events', '[{"id":3,"tags":["x","y"]}]');
----
raw.events	false	1	0	1	0

query II
SELECT id, tags FROM raw.events WHERE id = 3;
----
3	[x, y]

# ingestion is transactional with the caller
statement ok
BEGIN TRANSACTION;

statement ok
SELECT * FROM raw_ingest('raw.events', '[{"id":4}]');

statement ok
ROLLBACK;

query I
SELECT count(*) FROM raw.events;
----
3

# the store persists and reattaches
statement ok
DETACH raw;

statement ok
ATTACH 'rawduck:__TEST_DIR__/store.db' AS raw2;

query I
SELECT count(*) FROM raw2.events;
----
3

query I
SELECT name FROM raw2.events WHERE id = 2;
----
c

#===----------------------------------------------------------------------===#
# persisted statistics inside stores
#===----------------------------------------------------------------------===#

statement ok
SELECT count(*) FROM raw2.events WHERE id = 1;

query I
SELECT entries >= 1 FROM raw_stats_save('raw2');
----
true

query I
SELECT count(*) >= 1 FROM raw2.main.__rawduck_stats WHERE kind = 'column';
----
true

# stats survive in the store and merge back into the live cache
query I
SELECT entries >= 1 FROM raw_stats_load('raw2');
----
true

query I
SELECT filter_count >= 2 FROM raw_stats() WHERE "table" = 'raw2.main.events' AND "column" = 'id';
----
true

#===----------------------------------------------------------------------===#
# INSERT-syntax ingestion through the virtual ingest schema
#===----------------------------------------------------------------------===#

statement ok
INSERT INTO raw2.ingest.clicks VALUES ('{"id":1,"page":"/a"}'), ('{"id":2,"page":"/b","ms":1.5}');

query III
SELECT id, page, ms FROM raw2.clicks ORDER BY id;
----
1	/a	NULL
2	/b	1.5

# arrays and evolution through INSERT
statement ok
INSERT INTO raw2.ingest.clicks VALUES ('[{"id":3,"tags":["x","y"]}]');

query II
SELECT count(*), count(tags) FROM raw2.clicks;
----
3	1

# INSERT .. SELECT streams through the same path
statement ok
INSERT INTO raw2.ingest.clicks SELECT '{"id":' || range || '}' FROM range(4, 10);

query I
SELECT count(*) FROM raw2.clicks;
----
9

# ingest tables are write-only
statement error
SELECT * FROM raw2.ingest.clicks;
----
<REGEX>:.*write-only.*

# transforms apply to the INSERT lane via rawduck_insert_transform
statement ok
SET rawduck_insert_transform = 'otlp-traces';

statement ok
INSERT INTO raw2.ingest.spans VALUES ('{"resourceSpans":[{"resource":{"svc":"api"},"scopeSpans":[{"spans":[{"name":"s1","kind":2},{"name":"s2","kind":3}]}]}]}');

statement ok
RESET rawduck_insert_transform;

query III
SELECT name, kind, "resource.svc" FROM raw2.spans ORDER BY name;
----
s1	2	api
s2	3	api

# generic explode paths work through the same setting
statement ok
SET rawduck_insert_transform = 'data.items';

statement ok
INSERT INTO raw2.ingest.batchy VALUES ('{"env":"prod","data":{"items":[{"id":1},{"id":2}]}}');

statement ok
RESET rawduck_insert_transform;

query II
SELECT count(*), max(id) FROM raw2.batchy WHERE env = 'prod';
----
2	2
