{
	"name": "rawduck",
	"version": "1.0.0",
	"dependencies": [
		"zlib"
	],
	"default-features": [
		"protobuf"
	],
	"features": {
		"protobuf": {
			"description": "OTLP/protobuf request bodies on the HTTP API",
			"dependencies": [
				{
					"name": "protobuf",
					"platform": "!emscripten & !mingw"
				}
			]
		},
		"grpc": {
			"description": "OTLP/gRPC ingestion server",
			"dependencies": [
				{
					"name": "grpc",
					"platform": "!emscripten & !mingw"
				},
				{
					"name": "protobuf",
					"platform": "!emscripten & !mingw"
				}
			]
		}
	},
	"vcpkg-configuration": {
		"overlay-ports": [
			"./extension-ci-tools/vcpkg_ports"
		],
		"overlay-triplets": [
			"./vcpkg_triplets",
			"./extension-ci-tools/toolchains"
		]
	}
}